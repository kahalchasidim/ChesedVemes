/* ── helpers ──────────────────────────────────────────────── */

// Add `offsetMin` minutes to a time string "H:MM:SS" → "H:MM:SS"
function shiftTime(t, offsetMin) {
  if (!t || t.includes("--")) return "--:--:--";
  let p = t.split(':'), h = parseInt(p[0]), m = parseInt(p[1]), s = parseInt(p[2]||0);
  let total = (h*3600) + (m*60) + s + (offsetMin * 60);
  let nh = Math.floor(total/3600), nm = Math.floor((total%3600)/60), ns = total%60;
  if (nh > 12) nh -= 12; if (nh === 0) nh = 12;
  return nh + ":" + String(nm).padStart(2,'0') + ":" + String(ns).padStart(2,'0');
}

function fmtZman(t) {
  if (!t || t.includes("--")) return "--:--";
  let c = t.replace(/(AM|PM|am|pm)/g,"").trim();
  let p = c.split(':');
  return `${p[0]}:${p[1]}<span class="secs">:${p[2]||"00"}</span>`;
}

function getSec(t, pm) {
  if (!t || t.includes("--")) return 0;
  let p = t.split(':'), h = parseInt(p[0]), m = parseInt(p[1]), s = parseInt(p[2]||0);
  if (pm && h < 12) h += 12;
  return (h*3600) + (m*60) + s;
}

function getIso(d) {
  return d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2,'0') + "-" + String(d.getDate()).padStart(2,'0');
}

function fit(el, vhStart) {
  if (!el) return;
  let p = el.parentElement; let vh = vhStart; el.style.fontSize = vh + "vh";
  while (p.scrollHeight > p.clientHeight && vh > 1.0) { vh -= 0.1; el.style.fontSize = vh+"vh"; }
}

/* ── clock ──────────────────────────────────────────────── */
function updateClock() {
  let now = new Date();
  let h = now.getHours(), hh = (h%12||12);
  let mm = String(now.getMinutes()).padStart(2,'0');
  let ss = String(now.getSeconds()).padStart(2,'0');
  $('CLOCK').innerHTML =
    `<span class="c-unit">${hh}</span><span class="c-colon">:</span>` +
    `<span class="c-unit">${mm}</span><span class="c-colon">:</span>` +
    `<span class="c-unit">${ss}</span>`;
  $('ENG_DATE').innerText = now.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
}

