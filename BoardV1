  }, 800);
}

/* ── main UI update (every second) ─────────────────────── */
function updateUI() {
  let now = new Date();
  let h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();
  let cSec = (h*3600) + (m*60) + s;

  let dToday = schedule[getIso(now)]; if (!dToday) return;
  let holidayText = dToday.holidayText || "";

  // Stay-awake override for Shavuos
  let isHolidayStayAwake = holidayText.includes("שבועות");

  // Sleep: 1 AM – 5 AM
  if (!isHolidayStayAwake && h >= 1 && h < 5) {
    $('SLEEP_OVERLAY').style.display = 'block';
    $('SLEEP_CLOCK').innerText = (h%12||12)+":"+String(m).padStart(2,'0')+":"+String(s).padStart(2,'0');
    if (s === 0) {
      $('SLEEP_CLOCK').style.left = (Math.floor(Math.random()*70)+5)+"vw";
      $('SLEEP_CLOCK').style.top  = (Math.floor(Math.random()*80)+5)+"vh";
    }
    return;
  } else { $('SLEEP_OVERLAY').style.display = 'none'; }

  // ─ Flip logic ─
  // Shkia = z[9] (index 9, 0-based), which is position 10 in the 1-based sheet
  let shkiaSec = getSec(dToday.z[9], true);
  // Omer flips 25 min before the 60-min zman (i.e. shkia + 35 min)
  let sixtyMinSec = shkiaSec + (60 * 60);
  let oIso = (cSec >= (sixtyMinSec - 1500)) ? getIso(new Date(now.getTime()+86400000)) : getIso(now);
  let dIso = (cSec < getSec(dToday.z[0], false)) ? getIso(new Date(now.getTime()-86400000)) : getIso(now);
  let dOmer = schedule[oIso] || dToday, dDate = schedule[dIso] || dToday;

  // ─ Date / zmanim update (only on day flip) ─
  if (dIso !== lastDateIso) {
    lastDateIso = dIso;
    $('DAY_LABEL').innerText   = DAY_MAP[dDate.day] || dDate.day;
    $('DATE_LABEL').innerText  = dDate.heb;
    $('PARSHA_LABEL').innerText = dDate.parsha ? "פרשת " + dDate.parsha : "";

    // z1–z10: straight from sheet (alot→shkia, 10 values)
    for (let i = 1; i <= 10; i++) {
      $('z'+i).innerHTML = fmtZman(dDate.z[i-1]);
    }
    // z11 = tzet hakochavim — use sheet's z[10] if it exists, else shkia + ~18 min
    let tzet = dDate.z[10] || shiftTime(dDate.z[9], 18);
    $('z11').innerHTML = fmtZman(tzet);
    // z12 = shkia + 60 min (their "60-minute zman", no Rabbeinu Tam)
    $('z12').innerHTML = fmtZman(shiftTime(dDate.z[9], 60));
  }

  // ─ Omer / Moled / Holiday box ─
  let moledText   = dDate.moled || "";
  let isMoledTime = (cSec >= 32400 && cSec <= 45000);
  let omerKey     = dOmer.omerNum ? String(dOmer.omerNum).trim() : null;
  let summerMsg   = dOmer.clmF || defaultSummerMsg;

  if (isMoledTime && moledText !== "") {
    $('O2').innerText = moledText;
    $('O_BECHINA').style.display = 'none';
  } else if (holidayText !== "") {
    $('O2').innerText = holidayText;
    $('O_BECHINA').style.display = 'none';
  } else if (omerKey) {
    $('O2').innerText = "היום " + (OMER_STRINGS[omerKey] || omerKey+" יום") + " לעומר";
    if (dOmer.bechina) { $('O_BECHINA').innerText = dOmer.bechina; $('O_BECHINA').style.display = 'block'; }
    else { $('O_BECHINA').style.display = 'none'; }
  } else {
    $('O2').innerText = summerMsg;
    $('O_BECHINA').style.display = 'none';
  }
  fit($('O2'), 5.5); fit($('O_BECHINA'), 3.8);

  // ─ Status box ─
  let tR    = (dDate.tachReason || "").trim();
  let hText = (holidayText || "").trim();
  let dayW  = now.getDay();
  // For this shul: Shabbat begins at shkia (no candle-lighting advance)
  let isShab = (dayW===6 && cSec < shkiaSec) ||
               (dayW===5 && cSec >= shkiaSec);
  let isMotz = (dayW===6 && cSec >= shkiaSec);

  let head="", sub="", cls="default-box";

  if (isShab) {
    head = (moledText && isMoledTime) ? "שבת מברכים" : "שבת קודש";
    sub  = hText;
    cls  = "shab-box";
  } else if (hText !== "") {
    head = hText;
    sub  = isMotz ? "ותודיענו" : tR;
    cls  = "teal-box";
  } else if (isMotz) {
    head = "מוצאי שבת";
    sub  = "אתה חוננתנו";
    cls  = "default-box";
  } else if (tR !== "") {
    head = "אין אומרים תחנון";
    sub  = tR;
    cls  = "teal-box";
  } else {
    head = "מוריד הטל";
    sub  = "ותן ברכה";
    cls  = "default-box";
  }

  let sH = `<div class="message-box ${cls}"><span id="status-head">${head}</span><span id="status-sub">${sub}</span></div>`;
  if (sH !== currentStatusHTML) {
    $('LEFT_MSG').innerHTML = sH;
    currentStatusHTML = sH;
    fit($('status-head'), 6.0);
    fit($('status-sub'), 3.0);
  }

  // ─ Highlight next upcoming zman (rows r1–r12) ─
  let zRows = [];
  for (let i=1; i<=10; i++) zRows.push({id:'r'+i, sec: getSec(dDate.z[i-1], i>=7)});
  // tzet = z11
  let tzetVal = dDate.z[10] || shiftTime(dDate.z[9], 18);
  zRows.push({id:'r11', sec: getSec(tzetVal, true)});
  // 60-min = z12
  zRows.push({id:'r12', sec: shkiaSec + 3600});

  let nIdx  = zRows.findIndex(z => z.sec > cSec);
  let tgtId = nIdx !== -1 ? zRows[nIdx].id : null;
  if (tgtId !== currentlyHighlightedId) {
    document.querySelectorAll('.z-row').forEach(r => r.classList.remove('active-zman'));
    if (tgtId && $(tgtId)) $(tgtId).classList.add('active-zman');
    currentlyHighlightedId = tgtId;
  }
}

/* ── data loader ────────────────────────────────────────── */
function loadData() {
  fetch(SCRIPT_URL + "?cb=" + new Date().getTime())
    .then(r=>r.json()).then(d=>{
      if (!d) return;
      schedule        = d.schedule;
      defaultSummerMsg= d.defaultMsg || "";
      p1Images        = d.p1List || [];
      if (p1Images.length > 0 && !$('p1').getAttribute('src')) rotateP1();
      $('ANN').innerText = d.announcements || ""; fit($('ANN'), 4.8);
      $('TEF').innerText = d.tefila || "";        fit($('TEF'), 4.8);
      if (d.p4) $('p4').src = "https://drive.google.com/thumbnail?id="+d.p4+"&sz=w1200";
      if (d.p5) $('p5').src = "https://drive.google.com/thumbnail?id="+d.p5+"&sz=w1200";
    }).catch(()=>{});
}

/* ── init ──────────────────────────────────────────────── */
setInterval(updateClock, 1000); updateClock();
loadWeather(); setInterval(loadWeather, 900000);
loadData();    setInterval(loadData, 30000);
setInterval(updateUI, 1000); updateUI();
setInterval(rotateP1, 12000);
</script>
